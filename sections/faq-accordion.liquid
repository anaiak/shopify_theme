{% comment %}
  FAQ Accordion — Lightweight <details> based, no JS required.
  Keyboard-accessible, semantic HTML.
{% endcomment %}

<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} ol-section"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <div class="ol-section__heading">
      <h2 class="ol-section__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="ol-section__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ol-faq" role="list">
    {% for block in section.blocks %}
      <details class="ol-faq__item" role="listitem" {{ block.shopify_attributes }}>
        <summary class="ol-faq__question" aria-expanded="false">
          <span>{{ block.settings.question }}</span>
          <span class="ol-faq__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </span>
        </summary>
        <div class="ol-faq__answer">
          {{ block.settings.answer }}
        </div>
      </details>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "faq-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to know about our prints"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What paper do you use?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>All our prints are produced on 250gsm museum-grade matte paper with archival Giclée inks for vibrant, long-lasting colour.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "What paper do you use?", "answer": "<p>All our prints are produced on 250gsm museum-grade matte paper with archival Giclée inks for vibrant, long-lasting colour.</p>" } },
        { "type": "question", "settings": { "question": "How long does shipping take?", "answer": "<p>We ship within 2–3 business days. Standard delivery takes 3–7 business days within the EU, 5–12 days worldwide. Free shipping on orders over €50.</p>" } },
        { "type": "question", "settings": { "question": "Can I return or exchange a print?", "answer": "<p>Yes — we offer 30-day hassle-free returns. If your print arrives damaged or you're not satisfied, contact us and we'll sort it out.</p>" } },
        { "type": "question", "settings": { "question": "Do you offer framing?", "answer": "<p>Yes! Select prints are available with our premium solid-wood frames in black, white, or natural oak. Choose your frame option on the product page.</p>" } },
        { "type": "question", "settings": { "question": "Are your prints limited edition?", "answer": "<p>Some collections are limited runs. Check each product page for edition details. Once sold out, they won't be reprinted.</p>" } }
      ]
    }
  ]
}
{% endschema %}

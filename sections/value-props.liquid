{% comment %}
  Value Propositions Row — lightweight SVG icon + title + optional description.
  Designed for poster/art brands: shipping, quality, returns, eco, etc.
{% endcomment %}

<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} ol-section--sm"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <div class="ol-section__heading">
      <h2 class="ol-section__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="ol-section__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ol-value-props" role="list">
    {% for block in section.blocks %}
      <div class="ol-value-prop" role="listitem" {{ block.shopify_attributes }}>
        <div class="ol-value-prop__icon" aria-hidden="true">
          {% case block.settings.icon %}
            {% when 'shipping' %}
              <svg viewBox="0 0 24 24"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {% when 'quality' %}
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% when 'returns' %}
              <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            {% when 'eco' %}
              <svg viewBox="0 0 24 24"><path d="M12 22c-4.97 0-9-2.69-9-6v-.5C3 11.57 7.03 9 12 9s9 2.57 9 6.5V16c0 3.31-4.03 6-9 6z"/><path d="M12 2v7"/><path d="M8 5l4 4 4-4"/></svg>
            {% when 'secure' %}
              <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            {% when 'frame' %}
              <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="1"/><rect x="5" y="5" width="14" height="14" rx="0.5"/><line x1="12" y1="5" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="19"/><line x1="5" y1="12" x2="2" y2="12"/><line x1="22" y1="12" x2="19" y2="12"/></svg>
            {% when 'print' %}
              <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            {% else %}
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          {% endcase %}
        </div>
        <h3 class="ol-value-prop__title">{{ block.settings.title }}</h3>
        {% if block.settings.description != blank %}
          <p class="ol-value-prop__desc">{{ block.settings.description }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Value propositions",
  "tag": "section",
  "class": "value-props-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Shop With Us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium quality, fast delivery, and peace of mind"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "prop",
      "name": "Proposition",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "quality", "label": "Quality" },
            { "value": "returns", "label": "Returns" },
            { "value": "eco", "label": "Eco-friendly" },
            { "value": "secure", "label": "Secure" },
            { "value": "frame", "label": "Frame" },
            { "value": "print", "label": "Print / Package" },
            { "value": "info", "label": "Info" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "On orders over €50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value propositions",
      "blocks": [
        { "type": "prop", "settings": { "icon": "shipping", "title": "Free Shipping", "description": "On orders over €50" } },
        { "type": "prop", "settings": { "icon": "quality", "title": "Museum-Grade Prints", "description": "Giclée on 250gsm paper" } },
        { "type": "prop", "settings": { "icon": "returns", "title": "30-Day Returns", "description": "No questions asked" } },
        { "type": "prop", "settings": { "icon": "secure", "title": "Secure Checkout", "description": "SSL encrypted payment" } }
      ]
    }
  ]
}
{% endschema %}

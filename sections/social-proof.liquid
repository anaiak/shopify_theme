{% comment %}
  Social Proof / Testimonials — lightweight card grid, no JS.
{% endcomment %}

<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} ol-section"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  {% if section.settings.heading != blank %}
    <div class="ol-section__heading">
      <h2 class="ol-section__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="ol-section__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ol-testimonials" role="list">
    {% for block in section.blocks %}
      <blockquote class="ol-testimonial" role="listitem" {{ block.shopify_attributes }}>
        {% if block.settings.rating > 0 %}
          <div class="ol-testimonial__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}★{%- else -%}☆{%- endif -%}
            {%- endfor -%}
          </div>
        {% endif %}
        <p class="ol-testimonial__text">"{{ block.settings.text }}"</p>
        <footer>
          <p class="ol-testimonial__author">{{ block.settings.author }}</p>
          {% if block.settings.meta != blank %}
            <p class="ol-testimonial__meta">{{ block.settings.meta }}</p>
          {% endif %}
        </footer>
      </blockquote>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Social proof",
  "tag": "section",
  "class": "social-proof-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "text",
          "label": "Quote",
          "default": "The quality is incredible — my print looks like it belongs in a gallery."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Marie L."
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta text (location, product…)",
          "default": "Verified Buyer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social proof",
      "blocks": [
        { "type": "testimonial", "settings": { "rating": 5, "text": "The quality is incredible — my print looks like it belongs in a gallery.", "author": "Marie L.", "meta": "Verified Buyer" } },
        { "type": "testimonial", "settings": { "rating": 5, "text": "Beautifully packaged, arrived in perfect condition. Ordered three more for my living room.", "author": "Thomas K.", "meta": "Verified Buyer" } },
        { "type": "testimonial", "settings": { "rating": 5, "text": "The paper quality and colours exceeded my expectations. A truly premium feel.", "author": "Sophie R.", "meta": "Verified Buyer" } }
      ]
    }
  ]
}
{% endschema %}
